{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Node",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "outDir": "./dist",
        "rootDir": "./",
        "allowJs": true,
        "resolveJsonModule": true
    },
    "include": [
        "api/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "client",
        "server"
    ]
}