{
    "version": 2,
    "builds": [
        {
            "src": "api/*.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "server/*.pdf",
                    "server/*.txt"
                ]
            }
        },
        {
            "src": "client/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/index.ts"
        },
        {
            "src": "/(.*)",
            "dest": "client/$1"
        }
    ]
}